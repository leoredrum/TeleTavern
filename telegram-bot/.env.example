# Copy to .env and fill in real Telegram bot token.

# Telegram Bot Token from @BotFather. Format: <bot_id>:<base64ish>
TELEGRAM_BOT_TOKEN=

# OpenAI-compatible endpoint served by the bridge.
OPENAI_BASE_URL=http://127.0.0.1:8003/v1
OPENAI_API_KEY=tavern-v2-user-api-key-change-me

# Streaming edits to Telegram every N seconds while generating
EDIT_INTERVAL_S=1.0

# SQLite session DB (one row per Telegram chat)
DB_PATH=./data/sessions.db

# Log level for the bot
LOG_LEVEL=INFO