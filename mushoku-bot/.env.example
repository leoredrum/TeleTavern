# Scenario Bot .env.example
# Copy to .env (mode 600, gitignored) and fill in the token.
# Create your own bot with @BotFather. Do not reuse someone else's token.

# Telegram Bot Token from @BotFather. Format: <bot_id>:<base64ish>
TELEGRAM_BOT_TOKEN=

# MUSHOKU-dedicated bridge (Stage 3 isolation stack). Do NOT use the shared :8003.
OPENAI_BASE_URL=http://127.0.0.1:8017/v1
OPENAI_API_KEY=tavern-mushoku-user-api-key-change-me

# Optional: used only by the local direct-model fallback helper.
# Point this at your own SillyTavern character card PNG.
CHARACTER_CARD_PATH=

# Streaming edits to Telegram every N seconds while generating
EDIT_INTERVAL_S=1.0
REQUEST_TIMEOUT_S=180

# SQLite save DB (one row per Telegram chat) - isolated from V2 session DB
DB_PATH=../logs/mushoku_save.db

# Per-session directory (gitignored - no real RP content in git)
SESSIONS_DIR=./sessions

# Log level for the bot
LOG_LEVEL=INFO
