# SAENGMYEONG Bot .env.example
# Copy to .env (mode 600, gitignored) and fill in the token.
# Token is NEW (Leo 2026-06-30 owner-approved) - created via @BotFather
# with handle @leosaengmyeong_bot (Bot ID 8670105169), first_name 圣生.

# Telegram Bot Token from @BotFather. Format: <bot_id>:<base64ish>
TELEGRAM_BOT_TOKEN=

# SAENGMYEONG-dedicated bridge (Stage 3 isolation stack). Do NOT use shared :8003.
OPENAI_BASE_URL=http://127.0.0.1:8022/v1
OPENAI_API_KEY=tavern-saengmyeong-user-api-key-change-me

# Streaming edits to Telegram every N seconds while generating
EDIT_INTERVAL_S=1.0
REQUEST_TIMEOUT_S=180

# SQLite save DB (one row per Telegram chat) - isolated from V2 session DB
DB_PATH=../logs/saengmyeong_save.db

# Per-session directory (gitignored - no real RP content in git)
SESSIONS_DIR=./sessions

# Log level for the bot
LOG_LEVEL=INFO
