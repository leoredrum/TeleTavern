# Copy to .env and fill in the FOURTH bot token (create via @BotFather).
# This bot is independent from Penelope / June / Aqua.

# Telegram Bot Token from @BotFather. Format: <bot_id>:<base64ish>
TELEGRAM_BOT_TOKEN=

# DM-dedicated bridge (plan B). Do NOT use the shared :8003 — that endpoint
# fronts the ST instance whose active_character is Penelope3.
OPENAI_BASE_URL=http://127.0.0.1:8013/v1
OPENAI_API_KEY=tavern-dm-user-api-key-change-me

# Streaming edits to Telegram every N seconds while generating
EDIT_INTERVAL_S=1.0
REQUEST_TIMEOUT_S=180

# SQLite save DB (one row per Telegram chat) — isolated from V2 session DB
DB_PATH=../logs/dm_save.db

# Log level for the bot
LOG_LEVEL=INFO
