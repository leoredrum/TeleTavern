# V2 bridge configuration
# Copy to .env and fill in real values.

# User API (Telegram bot calls this on OpenAI-format requests)
USER_API_HOST=127.0.0.1
USER_API_PORT=8003
USER_API_KEY=tavern-v2-user-api-key-change-me

# WebSocket (ST extension connects here)
WS_HOST=127.0.0.1
WS_PORT=8001

# SillyTavern WebUI base URL (used for health checks)
ST_URL=http://127.0.0.1:8000

# How long to wait for ST to produce a reply before giving up
REQUEST_TIMEOUT_S=180

# Optional output language override.
# Common values: zh-CN, en, ja, none.
# mode=force: always use target language; prefer: soft preference; none/off: no prefix.
TELETAVERN_TARGET_LANGUAGE=zh-CN
TELETAVERN_LANGUAGE_MODE=force
TELETAVERN_PRESERVE_NAMES=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
